# clones/ holds junctions to the independent clone repos — each is its own git repo.
# The umbrella never tracks their contents; roster.json records the canonical paths.
clones/

# Generated per machine by tools/gen_agents.py (absolute local paths) — regenerate after clone.
.claude/agents/

# Per-machine autopilot worker identity + its journal. The default journal.jsonl
# stays committed; a machine that opts into a worker identity keeps its journal LOCAL
# so two machines running /roster-loop never conflict on it (ledgers are the truth for resume).
autopilot/worker
autopilot/journal-*.jsonl

# Python
__pycache__/
*.pyc

# Obsidian per-machine UI state (vault config app/appearance/core-plugins IS tracked)
.obsidian/workspace.json

# Local secrets — SSH keys for the VPS, credentials. NEVER commit these.
.secrets/
*.pem
*_ed25519
*_ed25519.pub
id_ed25519*
id_rsa*
