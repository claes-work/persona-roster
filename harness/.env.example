# Copy to harness/.env and fill in ONE key to start. All have free tiers.
# The harness loads harness/.env automatically (and never commits it).

# Google Gemini — https://aistudio.google.com/apikey  (generous free tier)
GEMINI_API_KEY=

# Mistral — https://console.mistral.ai/  (free tier)
MISTRAL_API_KEY=

# Groq — https://console.groq.com/keys  (free tier, very fast)
GROQ_API_KEY=
